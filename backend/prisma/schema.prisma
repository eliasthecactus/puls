generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  displayName  String
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  credentials        Credential[]
  history            WorkoutHistory[]
  customPlans        CustomPlan[]
  passkeyResetTokens PasskeyResetToken[]

  @@map("users")
}

model Credential {
  id           String   @id @default(uuid())
  userId       String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  deviceType   String?
  backedUp     Boolean  @default(false)
  transports   String[]
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
}

model WorkoutHistory {
  id          String   @id @default(uuid())
  userId      String
  workoutId   String
  workoutName String
  duration    Int
  intensity   String   @default("normal")
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@map("workout_history")
}

model Exercise {
  id               String   @id @default(uuid())
  nameDE           String
  nameEN           String
  detailDE         String   @default("")
  detailEN         String   @default("")
  formTipDE        String?
  formTipEN        String?
  imageUrl         String?
  primaryMuscles   String[]
  secondaryMuscles String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("exercises")
}

model CustomPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("custom_plans")
}

model PasskeyResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkey_reset_tokens")
}

model SystemPlan {
  id        String   @id @default(uuid())
  planetKey String   @unique
  subtitle  String   @default("")
  category  String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_plans")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}
